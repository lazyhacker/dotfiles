{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "blocks": [
    {
      "alignment": "left",
      "type": "prompt",
      "segments": [
        {
          "type": "shell",
          "style": "diamond",
          "background": "#0077c2",
          "foreground": "#ffffff",
          "template": " {{ .Name }} ",
          "leading_diamond": "╭─",
          "trailing_diamond": "\ue0b0"
        },
        {
          "type": "root",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#ef5350",
          "foreground": "#FFFB38",
          "template": " \ue0c1 "
        },
        {
          "type": "go",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#ffffff",
          "background": "#7FD5EA",
          "template": "  {{ .Full }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#FFFB38",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#ffeb95{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#c5e478{{ end }}",
            "{{ if gt .Ahead 0 }}#C792EA{{ end }}",
            "{{ if gt .Behind 0 }}#C792EA{{ end }}"
          ],
          "foreground": "#011627",
          "properties": {
            "branch_icon": "\ue0a0 ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .HEAD }} {{ if .Working.Changed }}{{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} S {{ .Staging.String }}{{ end }} "
        }
      ]
    },
    {
      "alignment": "right",
      "type": "prompt",
      "filler": "<#888888>─</>",
      "segments": [
        {
          "type": "node",
          "style": "powerline",
          "powerline_symbol": "\ue0b2",
          "invert_powerline": true,
          "background": "#303030",
          "foreground": "#3C873A",
          "properties": {
            "fetch_package_manager": true,
            "npm_icon": " npm ",
            "yarn_icon": " yarn "
          },
          "template": " node {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }}"
        },
        {
            "type": "python",
            "style": "powerline",
            "powerline_symbol": "",
            "foreground": "#ffd43b",
            "background": "#306998",
            "template": "  {{ .Full }} "
        }, 
        {
          "type": "time",
          "style": "diamond",
          "background": "#40c4ff",
          "foreground": "#ffffff",
          "leading_diamond": "\ue0b2",
          "template": " {{ .CurrentDate | date .Format }} "
        }
      ]
    },
    {
      "alignment": "left",
      "newline": true,
      "type": "prompt",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#21c7c7",
          "template": "╰─"
        },
        {
          "type": "path",
          "style": "diamond",
          "background": "#444444",
          "foreground": "#E4E4E4",
          "trailing_diamond": "\ue0b0",
          "properties": {
            "style": "full"
          },
          "template": " {{ .Path }} "
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "#e0f8ff",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#ef5350{{ end }}"
          ],
          "properties": {
            "always_enabled": true
          },
          "template": "  "
        }
      ]
    }
  ]
}
